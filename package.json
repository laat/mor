{
  "name": "mor",
  "version": "0.10.0",
  "description": "A shared memory store for humans and AI",
  "type": "module",
  "license": "MIT",
  "author": "Sigurd Fosseng <sigurd@fosseng.net>",
  "repository": {
    "type": "git",
    "url": "https://github.com/laat/mor.git"
  },
  "homepage": "https://github.com/laat/mor",
  "bugs": "https://github.com/laat/mor/issues",
  "keywords": [
    "memory",
    "ai",
    "mcp",
    "knowledge-base",
    "markdown",
    "sqlite",
    "fts5",
    "embeddings",
    "cli"
  ],
  "bin": {
    "mor": "dist/cli.js"
  },
  "man": [
    "./man/mor.1"
  ],
  "files": [
    "dist",
    "man"
  ],
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepublishOnly": "pnpm lint && pnpm test && pnpm build",
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.9",
    "sql-template-strings": "^2.2.2",
    "sqlite-vec": "^0.1.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
