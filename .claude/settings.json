{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/format.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": ".claude/hooks/lint.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
